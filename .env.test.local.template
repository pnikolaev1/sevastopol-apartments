# ──────────────────────────────────────────────────────────────────────────────
# Sevastopol Apartments — TEST environment template
#
# Copy this file to .env.local and replace the REPLACE_ME values with real ones.
# All other values are pre-filled and safe for testing.
#
# Order of setup:
#   1. Supabase  → DATABASE_URL + DIRECT_URL
#   2. Stripe    → STRIPE_SECRET_KEY + STRIPE_PUBLISHABLE_KEY + STRIPE_WEBHOOK_SECRET
#   3. Resend    → RESEND_API_KEY
#   4. Upstash   → UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN
# ──────────────────────────────────────────────────────────────────────────────

# ─── DATABASE (Supabase) ──────────────────────────────────────────────────────
# From: https://supabase.com → your project → Settings → Database → URI
# Use the "Session mode" pooler (port 6543) for DATABASE_URL
DATABASE_URL="REPLACE_ME_supabase_pooler_uri"
# Use the direct connection (port 5432) for DIRECT_URL — migrations only
DIRECT_URL="REPLACE_ME_supabase_direct_uri"

# ─── AUTH ─────────────────────────────────────────────────────────────────────
# For local dev use http://localhost:3000; for Vercel set to your *.vercel.app URL
NEXTAUTH_URL="http://localhost:3000"
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="REPLACE_ME_min_32_chars_base64"

# ─── STRIPE (TEST MODE) ───────────────────────────────────────────────────────
# From: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_REPLACE_ME"
STRIPE_PUBLISHABLE_KEY="pk_test_REPLACE_ME"
# From: https://dashboard.stripe.com/test/webhooks — after creating the endpoint
STRIPE_WEBHOOK_SECRET="whsec_REPLACE_ME"

# ─── RESEND (FREE TIER — TEST SENDER) ────────────────────────────────────────
# From: https://resend.com/api-keys
RESEND_API_KEY="re_REPLACE_ME"
# Use onboarding@resend.dev until your domain is verified in Resend
RESEND_FROM_EMAIL="onboarding@resend.dev"
RESEND_FROM_NAME="Sevastopol Apartments"

# ─── UPSTASH REDIS (FREE TIER) ────────────────────────────────────────────────
# From: https://console.upstash.com → your database → REST API
UPSTASH_REDIS_REST_URL="https://REPLACE_ME.upstash.io"
UPSTASH_REDIS_REST_TOKEN="REPLACE_ME"

# ─── APP ──────────────────────────────────────────────────────────────────────
# For local dev use localhost; change to your *.vercel.app URL after deploying
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_REPLACE_ME"
NEXT_PUBLIC_EUR_TO_BGN="1.95583"

# ─── STRIPE MODE ──────────────────────────────────────────────────────────────
# "test" shows the amber TEST MODE banner on the booking page
NEXT_PUBLIC_STRIPE_MODE="test"

# ─── SECURITY ─────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ICAL_HMAC_SECRET="REPLACE_ME_min_32_chars_hex"
CRON_SECRET="REPLACE_ME_min_32_chars_hex"

# ─── OWNER ───────────────────────────────────────────────────────────────────
OWNER_EMAIL="5areood@gmail.com"
OWNER_PHONE="+35989436230"
OWNER_WHATSAPP="35989436230"

# ─── NODE ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
