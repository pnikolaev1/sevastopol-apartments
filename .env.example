# ──────────────────────────────────────────────────────────────────────────────
# Sevastopol Apartments — Environment Variables
# Copy this file to .env.local and fill in every value before running.
# NEVER commit .env.local to git.
# ──────────────────────────────────────────────────────────────────────────────

# ─── DATABASE (Supabase) ──────────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → Database → Connection string
# Use the "URI" connection string with ?pgbouncer=true&connection_limit=1 for serverless
DATABASE_URL="postgresql://postgres.PROJECTREF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection (used for Prisma migrations only — no pooler)
DIRECT_URL="postgresql://postgres.PROJECTREF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# ─── NEXTAUTH / AUTH.JS ───────────────────────────────────────────────────────
# Your production URL (no trailing slash)
NEXTAUTH_URL="https://sevastopolapartments.com"

# Generate with: openssl rand -base64 32  (must be 32+ chars)
NEXTAUTH_SECRET="REPLACE_WITH_RANDOM_SECRET_MIN_32_CHARS"

# ─── STRIPE ───────────────────────────────────────────────────────────────────
# From: Stripe Dashboard → Developers → API keys
# Use sk_test_... / pk_test_... for testing, sk_live_... / pk_live_... for production
STRIPE_SECRET_KEY="sk_test_REPLACE_ME"
STRIPE_PUBLISHABLE_KEY="pk_test_REPLACE_ME"

# From: Stripe Dashboard → Developers → Webhooks → Signing secret
# Create webhook endpoint: https://sevastopolapartments.com/api/webhooks/stripe
# Events to enable: payment_intent.succeeded, payment_intent.payment_failed
STRIPE_WEBHOOK_SECRET="whsec_REPLACE_ME"

# ─── RESEND (email) ──────────────────────────────────────────────────────────
# From: Resend Dashboard → API Keys
RESEND_API_KEY="re_REPLACE_ME"

# Verified sending domain — add DNS records in Resend → Domains
# If testing without a custom domain, use "onboarding@resend.dev" temporarily
RESEND_FROM_EMAIL="bookings@sevastopolapartments.com"
RESEND_FROM_NAME="Sevastopol Apartments"

# ─── UPSTASH REDIS (rate limiting) ────────────────────────────────────────────
# From: Upstash Dashboard → Redis → REST API
UPSTASH_REDIS_REST_URL="https://REPLACE.upstash.io"
UPSTASH_REDIS_REST_TOKEN="REPLACE_ME"

# ─── APP ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://sevastopolapartments.com"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_REPLACE_ME"

# EUR to BGN fixed rate (Bulgaria's lev is pegged to EUR at 1.95583)
NEXT_PUBLIC_EUR_TO_BGN="1.95583"

# ─── iCAL SECURITY ───────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Used to sign the HMAC token in outbound iCal feed URLs
ICAL_HMAC_SECRET="REPLACE_WITH_RANDOM_SECRET_MIN_32_CHARS"

# ─── CRON JOB SECURITY ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Set the same value in Vercel env vars — Vercel Cron passes it as Authorization: Bearer
CRON_SECRET="REPLACE_WITH_RANDOM_HEX_SECRET"

# ─── STRIPE MODE ─────────────────────────────────────────────────────────────
# "test"  → shows TEST MODE banner on booking page, use sk_test_ / pk_test_ keys
# "live"  → hides banner, use sk_live_ / pk_live_ keys
NEXT_PUBLIC_STRIPE_MODE="test"

# ─── EMAIL MODE ───────────────────────────────────────────────────────────────
# "test"  → prefixes all subjects with [TEST MODE] + CCs owner on every guest email
# "live"  → standard production behaviour
EMAIL_MODE="test"

# ─── OWNER CONTACT ───────────────────────────────────────────────────────────
OWNER_EMAIL="5areood@gmail.com"
OWNER_PHONE="+35989436230"
OWNER_WHATSAPP="35989436230"

# ─── OPTIONAL: ERROR MONITORING (Sentry) ─────────────────────────────────────
# From: Sentry → Project Settings → Client Keys (DSN)
# SENTRY_DSN="https://KEY@sentry.io/PROJECT"
# NEXT_PUBLIC_SENTRY_DSN="https://KEY@sentry.io/PROJECT"

# ─── OPTIONAL: ANALYTICS (Plausible) ─────────────────────────────────────────
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN="sevastopolapartments.com"

# ─── NODE ─────────────────────────────────────────────────────────────────────
NODE_ENV="production"
